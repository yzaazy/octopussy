---
import { colorHex } from '../lib/colors';

interface Props {
  totalPieces: number;
  totalParts: number;
  usedColors: { id: number; name: string }[];
  studs: number;
}

const { totalPieces, totalParts, usedColors, studs } = Astro.props;
---

<header>
  <div class="masthead">
    <h1>Octopussy <span>kermis tracker</span></h1>
    <div class="sync" id="sync-status" data-state="loading">
      <span class="sync-dot"></span><span id="sync-label">Laden…</span>
    </div>
  </div>

  <div class="overall">
    <div class="studs" id="stud-bar" role="img" aria-label="Totale voortgang">
      {Array.from({ length: studs }).map((_, i) => <span class="stud" style={`--i: ${i}`}></span>)}
    </div>
    <p class="overall-count">
      <strong id="pieces-owned">0</strong> van <strong>{totalPieces}</strong> stenen ·
      <span id="parts-done">0</span>/{totalParts} onderdelen compleet
    </p>
  </div>

  <div class="controls">
    <div class="search-wrap">
      <input type="search" id="search" placeholder="Zoek onderdeel…" autocomplete="off" />
      <button type="button" id="scan-btn" aria-label="Scan een steen met je camera" title="Scan een steen met je camera">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
          <circle cx="12" cy="13" r="4" />
        </svg>
      </button>
      <input type="file" id="scan-input" accept="image/*" capture="environment" hidden />
    </div>
    <div class="field field-color">
      <label for="color-filter">Kleur</label>
      <select id="color-filter">
        <option value="">Alle kleuren</option>
        {usedColors.map((c) => (
          <option value={c.id}>
            <span class="opt-dot" style={`background:${colorHex(c.id)}`}></span>
            {c.name}
          </option>
        ))}
      </select>
    </div>
    <div class="field field-sort">
      <label for="sort-by">Sorteer</label>
      <select id="sort-by">
        <option value="color">Kleur</option>
        <option value="part">Onderdeelnummer</option>
        <option value="missing">Meeste nog nodig</option>
      </select>
    </div>
    <label class="missing-toggle">
      <input type="checkbox" id="missing-only" />
      Nog nodig
    </label>
  </div>
</header>

<div class="scan-panel" id="scan-panel" hidden>
  <div class="scan-box" role="dialog" aria-modal="true" aria-labelledby="scan-title">
    <div class="scan-head">
      <h3 id="scan-title">Steen scannen</h3>
      <button type="button" class="scan-close" aria-label="Sluiten">×</button>
    </div>
    <div class="scan-body"></div>
  </div>
</div>
