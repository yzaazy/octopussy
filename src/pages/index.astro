---
import { join } from 'node:path';
import { parseWantedList } from '../lib/parseWantedList';
import { colorName } from '../lib/colors';
import SiteHeader from '../components/SiteHeader.astro';
import PartSection from '../components/PartSection.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/global.css';

const sections = [
  { slug: 'octopussy', title: 'Octopussy', file: 'Octopussy.xml' },
  { slug: 'backwall', title: 'Achterwand', file: 'backwall octopussy.xml' },
  { slug: 'power', title: 'Motoren', file: 'Octopussy power.xml' },
].map((s) => {
  // resolve from the project root: Astro 7 prerenders from a bundle inside dist/,
  // so import.meta.url no longer points at the source tree
  const parts = parseWantedList(join(process.cwd(), s.file));
  return { ...s, parts, pieces: parts.reduce((n, p) => n + p.qtyNeeded, 0) };
});

const totalPieces = sections.reduce((n, s) => n + s.pieces, 0);
const totalParts = sections.reduce((n, s) => n + s.parts.length, 0);

const usedColors = [...new Set(sections.flatMap((s) => s.parts.map((p) => p.colorId)))]
  .map((id) => ({ id, name: colorName(id) }))
  .sort((a, b) => a.name.localeCompare(b.name));
const STUDS = 20;

// stamped by the Docker build (see Dockerfile); local builds show "dev"
const buildSha = (process.env.GIT_SHA ?? 'dev').slice(0, 7);
const buildDate = process.env.BUILD_DATE ?? '';
---

<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Octopussy kermis tracker</title>
    {/* use-credentials so the manifest fetch carries the Pangolin session cookie */}
    <link rel="manifest" href="/manifest.webmanifest" crossorigin="use-credentials" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#d8e7f4" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0e1b29" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="icon" type="image/png" href="/icons/icon-192.png" />
  </head>
  <body>
    <SiteHeader totalPieces={totalPieces} totalParts={totalParts} usedColors={usedColors} studs={STUDS} />

    <main>
      {sections.map((s) => <PartSection slug={s.slug} title={s.title} parts={s.parts} pieces={s.pieces} />)}
    </main>

    <SiteFooter buildSha={buildSha} buildDate={buildDate} />

    <script>
      import '../scripts/main';
    </script>
  </body>
</html>
